# ─────────────────────────────────────────────────────────────
# Production compose config.  cp .env.prod.example .env  and fill in.
# (This file is read by docker-compose.prod.yml for variable substitution.
#  Backend secrets like GROQ/Azure live in backend/.env, not here.)
# ─────────────────────────────────────────────────────────────

# Public domain that DNS points at this host (Caddy gets TLS for it).
DOMAIN=swasthya.example.com

# ── Database ──────────────────────────────────────────────────
# Option A (bundled Postgres): set a password; DATABASE_URL is derived.
POSTGRES_USER=swasthya
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=swasthya
# Option B (managed Neon): set DATABASE_URL and delete the postgres service.
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# ── Redis ─────────────────────────────────────────────────────
# Option A (bundled Redis): set a password; REDIS_URL is derived.
REDIS_PASSWORD=change-me-strong
# Option B (managed Upstash): set REDIS_URL and delete the redis service.
# REDIS_URL=rediss://default:pass@host.upstash.io:6379

# Backend workers (>1 is safe because REDIS_URL backs sessions).
WEB_CONCURRENCY=2

# ── Firebase (frontend build args — from your Firebase web app config) ──
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Live voice ICE (only needed for the "live" WebRTC mode) ───
# Push-to-talk voice (STT/TTS over HTTP) works WITHOUT any of these.
STUN_URL=stun:stun.l.google.com:19302
VITE_STUN_URL=stun:stun.l.google.com:19302
# If you run the coturn service (profile: turn), set matching creds here
# and in deploy/turnserver.conf:
# TURN_URLS=turn:swasthya.example.com:3478
# TURN_USERNAME=swasthya
# TURN_CREDENTIAL=change-me-strong
# VITE_TURN_URLS=turn:swasthya.example.com:3478
# VITE_TURN_USERNAME=swasthya
# VITE_TURN_CREDENTIAL=change-me-strong
