# ── Firebase Authentication Config ────────────────────────
# Required — the app is gated behind Firebase login and will not
# render past the Login screen without these.
#
# 1. Create a project at https://console.firebase.google.com (free Spark plan)
# 2. Build → Authentication → Sign-in method → enable Email/Password
# 3. Project settings → Your apps → Web app → copy the config values below
#
# Copy this file to `.env` before running `npm run dev` or `npm run build`.
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
