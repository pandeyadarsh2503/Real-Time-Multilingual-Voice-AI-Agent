# ─── LLM ─────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── Azure TTS ────────────────────────────────────────────
AZURE_TTS_KEY=your_azure_speech_key_here
AZURE_TTS_REGION=eastus

# ─── Exotel Outbound Calls ────────────────────────────────
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_SID=your_exotel_account_sid
EXOTEL_CALLER_ID=+91XXXXXXXXXX

# ─── Observability ───────────────────────────────────────
# "text" for local dev, "json" for production log aggregation.
LOG_FORMAT=text
# Optional bearer token protecting GET /metrics (Prometheus scrape).
METRICS_TOKEN=
# Optional OpenTelemetry tracing — point at any OTLP/HTTP gateway.
# Grafana Cloud free tier: Stack → OpenTelemetry → copy endpoint+auth:
#   OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-<region>.grafana.net/otlp
#   OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64 instanceID:token>
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=swasthyaai-backend

# ─── Redis (sessions + rate limiting) ────────────────────
# Optional locally (an in-process store is used when unset).
# Production: Upstash Redis free tier (https://upstash.com) — create a
# database and copy the redis:// / rediss:// connection URL:
#   REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
REDIS_URL=
# Sliding TTL for live conversations (seconds) and how long persisted
# transcripts are retained (days).
SESSION_TTL_SECONDS=1800
MEMORY_RETENTION_DAYS=30

# ─── Temporal (durable reminder workflows) ───────────────
# Optional. When set, reminder calls become durable Temporal workflows
# (persisted timers, automatic retries, full history in the UI);
# when empty, reminders fall back to a best-effort in-process timer.
#   Local dev:       temporal server start-dev   → localhost:7233
#   Docker profile:  docker compose --profile temporal up → temporal:7233
# Run the worker alongside the API: python worker.py
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=swasthya-reminders

# ─── Environment ──────────────────────────────────────────
# "production" hides /docs, /redoc and /openapi.json. Use "development"
# (default) or "staging" to keep the interactive API docs available.
ENVIRONMENT=development
# Clinic timezone — drives all "is this slot in the past?" decisions.
CLINIC_TIMEZONE=Asia/Kolkata

# ─── Authentication ───────────────────────────────────────
# Firebase project id (same value as VITE_FIREBASE_PROJECT_ID in
# frontend/.env). Required — every API endpoint verifies Firebase
# ID tokens against this project.
FIREBASE_PROJECT_ID=your-project-id
# Dev/CI escape hatch that disables auth entirely. NEVER in production.
AUTH_DISABLED=false
# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Max request-body size in bytes (JSON/form routes); audio uploads exempt.
MAX_REQUEST_BYTES=262144

# ─── Live voice (WebRTC ICE) ──────────────────────────────
# STUN lets the containerized backend learn its public address; without it
# live voice fails to connect for remote/NAT'd users. TURN relays when a
# peer is behind symmetric NAT or a UDP-blocking firewall (deploy coturn or
# a managed provider; TURN-over-TCP:443 is the most firewall-tolerant).
STUN_URL=stun:stun.l.google.com:19302
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# ─── Exotel webhook security ─────────────────────────────
# Public URL Exotel posts call status to, and the shared secret that
# must accompany it. Leave blank to disable the webhook.
EXOTEL_STATUS_CALLBACK_URL=
EXOTEL_WEBHOOK_TOKEN=

# ─── Database ─────────────────────────────────────────────
# Local development: SQLite (default).
# Production: Neon PostgreSQL free tier (https://neon.tech) — create a
# project, copy the pooled connection string, and it looks like:
#   DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Schema is managed by Alembic (backend/migrations); the app upgrades
# to head automatically on startup when pointed at PostgreSQL.
# NOTE: under docker-compose, use the mounted volume path so data persists:
#   DATABASE_URL=sqlite:////data/swasthya.db
DATABASE_URL=sqlite:///./swasthya.db

# ─── TTS Provider: "azure" or "gtts" ─────────────────────
TTS_PROVIDER=azure
